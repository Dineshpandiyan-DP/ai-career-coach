# Secrets — NEVER push to GitHub
.env

# Virtual environment — recreated by pip install -r requirements.txt
venv/

# Python compiled files — auto-generated by Python
__pycache__/
*.pyc
*.pyo

# Test cache — created when you run pytest
.pytest_cache/

# VS Code settings — your editor config, not project code
.vscode/

# Mac system file — created automatically on Mac, useless on Windows
.DS_Store

# Build files — created when you package your app
dist/
build/
*.egg-info/